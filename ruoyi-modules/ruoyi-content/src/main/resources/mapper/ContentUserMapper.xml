<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.content.mapper.ContentUserMapper">
    
    <resultMap type="ContentUser" id="ContentUserResult">
        <result property="userId"       column="user_id"      />
        <result property="userName"     column="user_name"    />
        <result property="nickName"     column="nick_name"    />
        <result property="userType"     column="user_type"    />
        <result property="email"        column="email"        />
        <result property="phonenumber"  column="phonenumber"  />
        <result property="sex"          column="sex"          />
        <result property="avatar"       column="avatar"       />
        <result property="password"     column="password"     />
        <result property="status"       column="status"       />
        <result property="delFlag"      column="del_flag"     />
        <result property="loginIp"      column="login_ip"     />
        <result property="loginDate"    column="login_date"   />
        <result property="pwdUpdateDate" column="pwd_update_date" />
        <result property="createBy"     column="create_by"    />
        <result property="createTime"   column="create_time"  />
        <result property="updateBy"     column="update_by"    />
        <result property="updateTime"   column="update_time"  />
        <result property="remark"       column="remark"       />
    </resultMap>

    <sql id="selectContentUserVo">
        select user_id, user_name, nick_name, user_type, email, phonenumber, sex, avatar, password, status, del_flag, login_ip, login_date, pwd_update_date, create_by, create_time, update_by, update_time, remark 
        from content_user
    </sql>

    <select id="selectContentUserList" parameterType="ContentUser" resultMap="ContentUserResult">
        <include refid="selectContentUserVo"/>
        <where>  
            <if test="userName != null and userName != ''">
                AND user_name like concat('%', #{userName}, '%')
            </if>
            <if test="nickName != null and nickName != ''">
                AND nick_name like concat('%', #{nickName}, '%')
            </if>
            <if test="userType != null and userType != ''">
                AND user_type = #{userType}
            </if>
            <if test="phonenumber != null and phonenumber != ''">
                AND phonenumber like concat('%', #{phonenumber}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
            AND del_flag = '0'
        </where>
    </select>
    
    <select id="selectContentUserById" parameterType="Long" resultMap="ContentUserResult">
        <include refid="selectContentUserVo"/>
        where user_id = #{userId}
    </select>
    
    <select id="selectContentUserByUserName" parameterType="String" resultMap="ContentUserResult">
        <include refid="selectContentUserVo"/>
        where user_name = #{userName} and del_flag = '0'
    </select>
        
    <select id="checkUserNameUnique" parameterType="String" resultMap="ContentUserResult">
        <include refid="selectContentUserVo"/>
        where user_name = #{userName} and del_flag = '0' limit 1
    </select>
        
    <insert id="insertContentUser" parameterType="ContentUser" useGeneratedKeys="true" keyProperty="userId">
        insert into content_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userName != null and userName != ''">user_name,</if>
            <if test="nickName != null and nickName != ''">nick_name,</if>
            <if test="userType != null and userType != ''">user_type,</if>
            <if test="email != null and email != ''">email,</if>
            <if test="phonenumber != null and phonenumber != ''">phonenumber,</if>
            <if test="sex != null and sex != ''">sex,</if>
            <if test="avatar != null and avatar != ''">avatar,</if>
            <if test="password != null and password != ''">password,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="loginIp != null and loginIp != ''">login_ip,</if>
            <if test="loginDate != null">login_date,</if>
            <if test="pwdUpdateDate != null">pwd_update_date,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userName != null and userName != ''">#{userName},</if>
            <if test="nickName != null and nickName != ''">#{nickName},</if>
            <if test="userType != null and userType != ''">#{userType},</if>
            <if test="email != null and email != ''">#{email},</if>
            <if test="phonenumber != null and phonenumber != ''">#{phonenumber},</if>
            <if test="sex != null and sex != ''">#{sex},</if>
            <if test="avatar != null and avatar != ''">#{avatar},</if>
            <if test="password != null and password != ''">#{password},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="loginIp != null and loginIp != ''">#{loginIp},</if>
            <if test="loginDate != null">#{loginDate},</if>
            <if test="pwdUpdateDate != null">#{pwdUpdateDate},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateContentUser" parameterType="ContentUser">
        update content_user
        <trim prefix="SET" suffixOverrides=",">
            <if test="userName != null and userName != ''">user_name = #{userName},</if>
            <if test="nickName != null and nickName != ''">nick_name = #{nickName},</if>
            <if test="userType != null and userType != ''">user_type = #{userType},</if>
            <if test="email != null and email != ''">email = #{email},</if>
            <if test="phonenumber != null and phonenumber != ''">phonenumber = #{phonenumber},</if>
            <if test="sex != null and sex != ''">sex = #{sex},</if>
            <if test="avatar != null and avatar != ''">avatar = #{avatar},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
            <if test="loginIp != null and loginIp != ''">login_ip = #{loginIp},</if>
            <if test="loginDate != null">login_date = #{loginDate},</if>
            <if test="pwdUpdateDate != null">pwd_update_date = #{pwdUpdateDate},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where user_id = #{userId}
    </update>

    <delete id="deleteContentUserById" parameterType="Long">
        update content_user set del_flag = '2' where user_id = #{userId}
    </delete>

    <delete id="deleteContentUserByIds" parameterType="Long">
        update content_user set del_flag = '2' where user_id in 
        <foreach item="userId" collection="array" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </delete>

    <select id="getViewHistory" parameterType="Long" resultType="java.util.Map">
        SELECT 
            h.content_id as contentId,
            c.title,
            c.summary,
            c.cover_image as coverImage,
            cat.category_name as categoryName,
            h.view_time as viewTime
        FROM content_view_history h
        LEFT JOIN content_info c ON h.content_id = c.content_id
        LEFT JOIN content_category cat ON c.category_id = cat.category_id
        WHERE h.user_id = #{userId}
        ORDER BY h.view_time DESC
        LIMIT 20
    </select>

    <insert id="insertViewHistory" parameterType="map">
        INSERT INTO content_view_history (user_id, content_id, view_time, create_time)
        VALUES (#{userId}, #{contentId}, NOW(), NOW())
        ON DUPLICATE KEY UPDATE view_time = NOW()
    </insert>

    <select id="searchUsers" parameterType="String" resultMap="ContentUserResult">
        <include refid="selectContentUserVo"/>
        WHERE del_flag = '0' AND status = '0'
        AND (user_name like concat('%', #{keyword}, '%') OR nick_name like concat('%', #{keyword}, '%'))
        LIMIT 20
    </select>
</mapper>
