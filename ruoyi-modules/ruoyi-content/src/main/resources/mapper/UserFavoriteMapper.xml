<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.content.mapper.UserFavoriteMapper">
    
    <resultMap type="UserFavorite" id="UserFavoriteResult">
        <result property="favoriteId"       column="favorite_id"       />
        <result property="userId"           column="user_id"           />
        <result property="contentId"        column="content_id"        />
        <result property="favoriteTime"     column="favorite_time"     />
        <result property="createBy"         column="create_by"         />
        <result property="createTime"       column="create_time"       />
        <result property="updateBy"         column="update_by"         />
        <result property="updateTime"       column="update_time"       />
        <result property="remark"           column="remark"            />
    </resultMap>

    <sql id="selectUserFavoriteVo">
        select favorite_id, user_id, content_id, favorite_time, create_by, create_time, update_by, update_time, remark from user_favorite
    </sql>

    <select id="selectUserFavoriteList" parameterType="UserFavorite" resultMap="UserFavoriteResult">
        <include refid="selectUserFavoriteVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="contentId != null "> and content_id = #{contentId}</if>
            <if test="favoriteTime != null "> and favorite_time = #{favoriteTime}</if>
        </where>
        order by favorite_time desc
    </select>
    
    <select id="selectUserFavoriteListByUserId" parameterType="Long" resultMap="UserFavoriteResult">
        <include refid="selectUserFavoriteVo"/>
        where user_id = #{userId}
        order by favorite_time desc
    </select>
    
    <select id="selectUserFavoriteCount" parameterType="map" resultType="int">
        select count(*) from user_favorite where user_id = #{userId} and content_id = #{contentId}
    </select>
    
    <select id="selectUserFavoriteByFavoriteId" parameterType="Long" resultMap="UserFavoriteResult">
        <include refid="selectUserFavoriteVo"/>
        where favorite_id = #{favoriteId}
    </select>
        
    <insert id="insertUserFavorite" parameterType="UserFavorite" useGeneratedKeys="true" keyProperty="favoriteId">
        insert into user_favorite
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="contentId != null">content_id,</if>
            <if test="favoriteTime != null">favorite_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="contentId != null">#{contentId},</if>
            <if test="favoriteTime != null">#{favoriteTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateUserFavorite" parameterType="UserFavorite">
        update user_favorite
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="contentId != null">content_id = #{contentId},</if>
            <if test="favoriteTime != null">favorite_time = #{favoriteTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where favorite_id = #{favoriteId}
    </update>

    <delete id="deleteUserFavoriteByFavoriteId" parameterType="Long">
        delete from user_favorite where favorite_id = #{favoriteId}
    </delete>

    <delete id="deleteUserFavoriteByUserIdAndContentId" parameterType="map">
        delete from user_favorite where user_id = #{userId} and content_id = #{contentId}
    </delete>

    <delete id="deleteUserFavoriteByFavoriteIds" parameterType="String">
        delete from user_favorite where favorite_id in 
        <foreach item="favoriteId" collection="array" open="(" separator="," close=")">
            #{favoriteId}
        </foreach>
    </delete>

    <delete id="deleteUserFavoriteByUserId" parameterType="Long">
        delete from user_favorite where user_id = #{userId}
    </delete>

</mapper>
