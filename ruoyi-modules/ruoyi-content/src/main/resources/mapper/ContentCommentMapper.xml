<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.content.mapper.ContentCommentMapper">

    <resultMap type="ContentComment" id="ContentCommentResult">
        <result property="commentId"    column="comment_id"    />
        <result property="contentId"    column="content_id"    />
        <result property="userId"       column="user_id"       />
        <result property="parentId"     column="parent_id"     />
        <result property="content"      column="content"       />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
        <result property="nickName"     column="nick_name"     />
        <result property="avatar"       column="avatar"        />
    </resultMap>

    <sql id="selectContentCommentVo">
        select cc.comment_id, cc.content_id, cc.user_id, cc.parent_id, cc.content, cc.status,
               cc.create_by, cc.create_time, cc.update_by, cc.update_time, cc.remark,
               cu.nick_name, cu.avatar
        from content_comment cc
        left join content_user cu on cc.user_id = cu.user_id
    </sql>

    <select id="selectContentCommentList" parameterType="ContentComment" resultMap="ContentCommentResult">
        <include refid="selectContentCommentVo"/>
        <where>
            <if test="contentId != null"> and cc.content_id = #{contentId}</if>
            <if test="userId != null"> and cc.user_id = #{userId}</if>
            <if test="parentId != null"> and cc.parent_id = #{parentId}</if>
            <if test="status != null and status != ''"> and cc.status = #{status}</if>
        </where>
        order by cc.create_time desc
    </select>

    <select id="selectContentCommentById" parameterType="Long" resultMap="ContentCommentResult">
        <include refid="selectContentCommentVo"/>
        where cc.comment_id = #{commentId}
    </select>

    <insert id="insertContentComment" parameterType="ContentComment" useGeneratedKeys="true" keyProperty="commentId">
        insert into content_comment (content_id, user_id, parent_id, content, status, create_by, create_time)
        values (#{contentId}, #{userId}, #{parentId}, #{content}, #{status}, #{createBy}, sysdate())
    </insert>

    <update id="updateContentComment" parameterType="ContentComment">
        update content_comment
        <set>
            <if test="content != null">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where comment_id = #{commentId}
    </update>

    <delete id="deleteContentCommentByIds" parameterType="Long">
        delete from content_comment where comment_id in
        <foreach item="commentId" collection="array" open="(" separator="," close=")">
            #{commentId}
        </foreach>
    </delete>

    <delete id="deleteContentCommentById" parameterType="Long">
        delete from content_comment where comment_id = #{commentId}
    </delete>
</mapper>
